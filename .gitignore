*.pyc
*.pyo
exports/
.claude/

# Agent-initiated .pssession exports (export_session tool default dir)
agent_exports/

# User-data preset / sequence stores (CMU.17.034). Presets are user data,
# not code; the per-user store lives outside the repo, and any local
# *.mux16 / *.mux16seq files a user drops in the tree stay untracked.
# Built-in presets remain in code; presets/presets.json is the one-time
# migration source -- untracked (git rm --cached) but kept on disk.
*.mux16
*.mux16seq
/presets/presets.json

# Raw serial bench-capture logs (EMSTAT_RAW_CAPTURE diagnostics)
bench_captures/
